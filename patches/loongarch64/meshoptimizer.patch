+static void decodeFilterExpSimd(unsigned int* data, size_t count)
+{
+	for (size_t i = 0; i < count; i += 4)
+	{
+		v4i32 v = (v4i32)__lsx_vld(&data[i], 0);
+
+		v4i32 ef = __lsx_vsrai_w(v, 24);
+		v4i32 es = __lsx_vslli_w(__lsx_vadd_w(ef, (v4i32)__lsx_vreplgr2vr_w(127)), 23);
+
+		v4i32 mf = __lsx_vsrai_w(__lsx_vslli_w(v, 8), 8);
+		v4f32 m = __lsx_vffint_s_w(mf);
+
+		v4f32 r = __lsx_vfmul_s((v4f32)es, m);
+
+		__lsx_vst((v16u8)r, (unsigned char*)&data[i], 0);
+	}
+}
