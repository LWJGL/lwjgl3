+static void decodeFilterColorSimd8(unsigned char* data, size_t count)
+{
+	for (size_t i = 0; i < count; i += 4)
+	{
+		v4i32 c4 = (v4i32)__lsx_vld(&data[i * 4], 0);
+
+		v4i32 yf = __lsx_vand_v(c4, (v4i32)__lsx_vreplgr2vr_w(0xff));
+		v4i32 cof = __lsx_vsrai_w(__lsx_vslli_w(c4, 16), 24);
+		v4i32 cgf = __lsx_vsrai_w(__lsx_vslli_w(c4, 8), 24);
+		v4i32 af = (v4i32)__lsx_vsrli_w((v4u32)c4, 24);
+
+		v4i32 as = af;
+		as = __lsx_vor_v((v16u8)as, (v16u8)__lsx_vsrai_w(as, 1));
+		as = __lsx_vor_v((v16u8)as, (v16u8)__lsx_vsrai_w(as, 2));
+		as = __lsx_vor_v((v16u8)as, (v16u8)__lsx_vsrai_w(as, 4));
+
+		af = __lsx_vor_v((v16u8)__lsx_vand_v((v16u8)__lsx_vslli_w(af, 1), (v16u8)as),
+		                 (v16u8)__lsx_vand_v((v16u8)af, (v16u8)__lsx_vreplgr2vr_w(1)));
+
+		v4f32 ss = __lsx_vfmul_s((v4f32)__lsx_vreplgr2vr_w(0x437f0000),
+		    __lsx_vfrecip_s(__lsx_vffint_s_w(as)));
+
+		v4i32 rf = __lsx_vadd_w(yf, __lsx_vsub_w(cof, cgf));
+		v4i32 gf = __lsx_vadd_w(yf, cgf);
+		v4i32 bf = __lsx_vsub_w(yf, __lsx_vadd_w(cof, cgf));
+
+		const v4f32 fsnap = (v4f32)__lsx_vreplgr2vr_w(0x4B400000);
+
+		v4i32 rr = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(rf), ss, fsnap);
+		v4i32 gr = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(gf), ss, fsnap);
+		v4i32 br = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(bf), ss, fsnap);
+		v4i32 ar = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(af), ss, fsnap);
+
+		v4i32 res = __lsx_vor_v(
+		    (v16u8)rr,
+		    __lsx_vor_v(
+		        __lsx_vslli_w(gr, 8),
+		        __lsx_vor_v(
+		            __lsx_vslli_w(br, 16),
+		            __lsx_vslli_w(ar, 24))));
+
+		__lsx_vst((v16u8)res, &data[i * 4], 0);
+	}
+}
