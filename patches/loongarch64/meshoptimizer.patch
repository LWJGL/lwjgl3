+static void decodeFilterQuatSimd(short* data, size_t count)
+{
+	const float scale_val = 32767.f / sqrtf(2.f);
+	v4f32 scale_v = (v4f32)__lsx_vreplgr2vr_w(*(int*)&scale_val);
+
+	for (size_t i = 0; i < count; i += 4)
+	{
+		v4i32 q4_0 = (v4i32)__lsx_vld(&data[(i + 0) * 4], 0);
+		v4i32 q4_1 = (v4i32)__lsx_vld(&data[(i + 2) * 4], 0);
+
+		v4i32 q4_xy = __lsx_vilvl_w(q4_1, q4_0);
+		v4i32 q4_zc = __lsx_vilvh_w(q4_1, q4_0);
+
+		v4i32 xf = __lsx_vsrai_w(__lsx_vslli_w(q4_xy, 16), 16);
+		v4i32 yf = __lsx_vsrai_w(q4_xy, 16);
+		v4i32 zf = __lsx_vsrai_w(__lsx_vslli_w(q4_zc, 16), 16);
+		v4i32 cf = __lsx_vsrai_w(q4_zc, 16);
+
+		v4i32 sf = __lsx_vor_v((v16u8)cf, (v16u8)__lsx_vreplgr2vr_w(3));
+		v4f32 s = __lsx_vffint_s_w(sf);
+
+		v4f32 x = __lsx_vffint_s_w(xf);
+		v4f32 y = __lsx_vffint_s_w(yf);
+		v4f32 z = __lsx_vffint_s_w(zf);
+
+		v4f32 ws = __lsx_vfmul_s(s, s);
+		v4f32 ww = __lsx_vfsub_s(__lsx_vfadd_s(ws, ws),
+		    __lsx_vfmadd_s(y, y, __lsx_vfmadd_s(x, x, __lsx_vfmul_s(z, z))));
+		v4f32 w = __lsx_vfsqrt_s(__lsx_vfmax_s(ww, (v4f32)__lsx_vreplgr2vr_w(0)));
+
+		v4f32 ss = __lsx_vfdiv_s(scale_v, s);
+
+		const v4f32 fsnap = (v4f32)__lsx_vreplgr2vr_w(0x4B400000);
+
+		v4i32 xr = (v4i32)__lsx_vfmadd_s(x, ss, fsnap);
+		v4i32 yr = (v4i32)__lsx_vfmadd_s(y, ss, fsnap);
+		v4i32 zr = (v4i32)__lsx_vfmadd_s(z, ss, fsnap);
+		v4i32 wr = (v4i32)__lsx_vfmadd_s(w, ss, fsnap);
+
+		v4i32 xzr = __lsx_vor_v((v16u8)xr, __lsx_vslli_w(zr, 16));
+		v4i32 wyr = __lsx_vor_v((v16u8)wr, __lsx_vslli_w(yr, 16));
+
+		v2i64 res_0 = (v2i64)__lsx_vilvl_h((v8i16)xzr, (v8i16)wyr);
+		v2i64 res_1 = (v2i64)__lsx_vilvh_h((v8i16)xzr, (v8i16)wyr);
+
+		volatile v2i64 res[2];
+		__lsx_vst((v16u8)res_0, (unsigned char*)&res[0], 0);
+		__lsx_vst((v16u8)res_1, (unsigned char*)&res[1], 0);
+
+		uint64_t out[4];
+		out[0] = rotateleft64((uint64_t)(res[0][0]), data[(i + 0) * 4 + 3] << 4);
+		out[1] = rotateleft64((uint64_t)(res[0][1]), data[(i + 1) * 4 + 3] << 4);
+		out[2] = rotateleft64((uint64_t)(res[1][0]), data[(i + 2) * 4 + 3] << 4);
+		out[3] = rotateleft64((uint64_t)(res[1][1]), data[(i + 3) * 4 + 3] << 4);
+		memcpy(&data[i * 4], out, 4 * sizeof(uint64_t));
+	}
+}
