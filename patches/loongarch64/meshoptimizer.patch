+static void decodeFilterColorSimd16(unsigned short* data, size_t count)
+{
+	for (size_t i = 0; i < count; i += 4)
+	{
+		v4i32 c4_0 = (v4i32)__lsx_vld(&data[(i + 0) * 4], 0);
+		v4i32 c4_1 = (v4i32)__lsx_vld(&data[(i + 2) * 4], 0);
+
+		v4i32 c4_yco = __lsx_vilvl_w(c4_1, c4_0);
+		v4i32 c4_cga = __lsx_vilvh_w(c4_1, c4_0);
+
+		v4i32 yf = __lsx_vand_v(c4_yco, (v4i32)__lsx_vreplgr2vr_w(0xffff));
+		v4i32 cof = __lsx_vsrai_w(c4_yco, 16);
+		v4i32 cgf = __lsx_vsrai_w(__lsx_vslli_w(c4_cga, 16), 16);
+		v4i32 af = (v4i32)__lsx_vsrli_w((v4u32)c4_cga, 16);
+
+		v4i32 as = af;
+		as = __lsx_vor_v((v16u8)as, (v16u8)__lsx_vsrai_w(as, 1));
+		as = __lsx_vor_v((v16u8)as, (v16u8)__lsx_vsrai_w(as, 2));
+		as = __lsx_vor_v((v16u8)as, (v16u8)__lsx_vsrai_w(as, 4));
+		as = __lsx_vor_v((v16u8)as, (v16u8)__lsx_vsrai_w(as, 8));
+
+		af = __lsx_vor_v((v16u8)__lsx_vand_v((v16u8)__lsx_vslli_w(af, 1), (v16u8)as),
+		                 (v16u8)__lsx_vand_v((v16u8)af, (v16u8)__lsx_vreplgr2vr_w(1)));
+
+		v4f32 ss = __lsx_vfdiv_s((v4f32)__lsx_vreplgr2vr_w(0x477fff00), __lsx_vffint_s_w(as));
+
+		v4i32 rf = __lsx_vadd_w(yf, __lsx_vsub_w(cof, cgf));
+		v4i32 gf = __lsx_vadd_w(yf, cgf);
+		v4i32 bf = __lsx_vsub_w(yf, __lsx_vadd_w(cof, cgf));
+
+		const v4f32 fsnap = (v4f32)__lsx_vreplgr2vr_w(0x4B400000);
+
+		v4i32 rr = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(rf), ss, fsnap);
+		v4i32 gr = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(gf), ss, fsnap);
+		v4i32 br = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(bf), ss, fsnap);
+		v4i32 ar = (v4i32)__lsx_vfmadd_s(__lsx_vffint_s_w(af), ss, fsnap);
+
+		v4i32 rbr = __lsx_vor_v((v16u8)rr, __lsx_vslli_w(br, 16));
+		v4i32 gar = __lsx_vor_v((v16u8)gr, __lsx_vslli_w(ar, 16));
+
+		v4i32 res_0 = __lsx_vilvl_h((v8i16)gar, (v8i16)rbr);
+		v4i32 res_1 = __lsx_vilvh_h((v8i16)gar, (v8i16)rbr);
+
+		__lsx_vst((v16u8)res_0, (unsigned char*)&data[(i + 0) * 4], 0);
+		__lsx_vst((v16u8)res_1, (unsigned char*)&data[(i + 2) * 4], 0);
+	}
+}
