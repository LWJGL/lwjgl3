+static void decodeFilterOctSimd16(short* data, size_t count)
+{
+	const v4i32 sign = (v4i32)__lsx_vreplgr2vr_w(0x80000000);
+
+	for (size_t i = 0; i < count; i += 4)
+	{
+		v4i32 n4_0 = (v4i32)__lsx_vld(&data[(i + 0) * 4], 0);
+		v4i32 n4_1 = (v4i32)__lsx_vld(&data[(i + 2) * 4], 0);
+
+		v4i32 n4 = __lsx_vilvl_w(n4_1, n4_0);
+
+		v4i32 xf = __lsx_vsrai_w(__lsx_vslli_w(n4, 16), 16);
+		v4i32 yf = __lsx_vsrai_w(n4, 16);
+
+		v4i32 z4 = __lsx_vilvh_w(n4_1, n4_0);
+		v4i32 zf = __lsx_vand_v(z4, (v4i32)__lsx_vreplgr2vr_w(0x7fff));
+
+		v4f32 x = __lsx_vffint_s_w(xf);
+		v4f32 y = __lsx_vffint_s_w(yf);
+		v4f32 z = __lsx_vfsub_s(__lsx_vffint_s_w(zf), __lsx_vfadd_s(__lsx_vfabs_s(x), __lsx_vfabs_s(y)));
+
+		v4f32 t = __lsx_vfmin_s(z, (v4f32)__lsx_vreplgr2vr_w(0));
+
+		x = __lsx_vfadd_s(x, (v4f32)__lsx_vxor_v((v16u8)t, __lsx_vand_v((v16u8)x, (v16u8)sign)));
+		y = __lsx_vfadd_s(y, (v4f32)__lsx_vxor_v((v16u8)t, __lsx_vand_v((v16u8)y, (v16u8)sign)));
+
+		v4f32 ll = __lsx_vfmadd_s(y, y, __lsx_vfmadd_s(x, x, __lsx_vfmul_s(z, z)));
+		v4f32 s = __lsx_vfdiv_s((v4f32)__lsx_vreplgr2vr_w(0x46fffe00), __lsx_vfsqrt_s(ll));
+
+		const v4f32 fsnap = (v4f32)__lsx_vreplgr2vr_w(0x4B400000);
+
+		v4i32 xr = (v4i32)__lsx_vfmadd_s(x, s, fsnap);
+		v4i32 yr = (v4i32)__lsx_vfmadd_s(y, s, fsnap);
+		v4i32 zr = (v4i32)__lsx_vfmadd_s(z, s, fsnap);
+
+		v4i32 xzr = __lsx_vor_v((v16u8)xr, __lsx_vslli_w(zr, 16));
+		v4i32 y0r = __lsx_vand_v(yr, (v4i32)__lsx_vreplgr2vr_w(0xffff));
+
+		v4i32 res_0 = __lsx_vilvl_h((v8i16)y0r, (v8i16)xzr);
+		v4i32 res_1 = __lsx_vilvh_h((v8i16)y0r, (v8i16)xzr);
+
+		v16u8 wmask = (v16u8)__lsx_vreplgr2vr_w(0xffff0000);
+		res_0 = __lsx_vbitsel_v((v16u8)res_0, (v16u8)n4_0, wmask);
+		res_1 = __lsx_vbitsel_v((v16u8)res_1, (v16u8)n4_1, wmask);
+
+		__lsx_vst((v16u8)res_0, &data[(i + 0) * 4], 0);
+		__lsx_vst((v16u8)res_1, &data[(i + 2) * 4], 0);
+	}
+}
